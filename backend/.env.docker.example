# Copy this to backend/.env on the VPS and fill in the real values.
# docker-compose reads it via `env_file: ./backend/.env`.

PORT=5000
NODE_ENV=production

# Supabase connection string (Settings -> Database -> Connection string -> URI).
# URL-encode special chars in the password (@ = %40, # = %23, ! = %21).
DATABASE_URL=postgresql://postgres:<YOUR_SUPABASE_PASSWORD>@db.lxednjurpshwzaqcfyrp.supabase.co:5432/postgres

# JWT (use a long random string)
JWT_SECRET=<CHANGE_ME_TO_A_LONG_RANDOM_STRING>
JWT_EXPIRES_IN=7d

# File storage (paths inside the container; mounted to ./data on the host)
UPLOAD_DIR=uploads
GENERATED_DIR=generated
MAX_PHOTO_SIZE_MB=5
MAX_PHOTOS=20

# Same-origin behind nginx, so CORS is not really used; set to your server URL.
FRONTEND_URL=http://YOUR_VPS_IP
