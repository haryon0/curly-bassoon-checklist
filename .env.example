# Database
DATABASE_URL=postgresql://postgres:password@host:5432/database

# Authentication
JWT_SECRET=your-super-secret-key-min-32-chars-long-string-here
JWT_EXPIRES_IN=7d

# Environment
NODE_ENV=production
FRONTEND_URL=https://your-domain.com

# Database Config (optional, for local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=checklist_db
DB_USER=postgres
DB_PASSWORD=password
